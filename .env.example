# ============================================
# OpenClaw 环境配置文件
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实配置值
# 3. 推送到 Vercel 时，将这些环境变量添加到项目设置中
#
# ============================================

# ── LLM（大模型配置）──
# 支持 OpenAI / DeepSeek / 硅基流动 等兼容接口
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# 演示模式（无需真实API密钥）：
# LLM_API_KEY=demo

# ── Supabase（数据库配置）──
# 获取方法：访问 Supabase 项目 → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 内存模式（无需数据库）：
# 不填上述两项即可，系统自动降级为内存模式

# ── 服务配置 ──
PORT=3000
NODE_ENV=production

# ============================================
# 配置示例
# ============================================

# 示例1：演示模式（推荐用于快速测试）
# LLM_API_KEY=demo
# （不配置 Supabase，使用内存模式）

# 示例2：生产模式（完整功能）
# LLM_API_KEY=sk-proj-abc123...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# SUPABASE_URL=https://abc123.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGci...

# 示例3：使用 DeepSeek
# LLM_API_KEY=sk-abc123...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# SUPABASE_URL=https://abc123.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGci...

# ============================================
