{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/status", "dest": "/index.js" },
    { "src": "/agents", "dest": "/index.js" },
    { "src": "/chat", "dest": "/index.js" },
    { "src": "/agent/(.*)", "dest": "/index.js" },
    { "src": "/session/(.*)", "dest": "/index.js" }
  ]
}
