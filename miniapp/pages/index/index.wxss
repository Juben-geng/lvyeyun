/* pages/index/index.wxss */
.container { padding-bottom: 40rpx; background: #f5f5f5; min-height: 100vh; }

.hero {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
  padding: 80rpx 40rpx 60rpx;
  border-radius: 0 0 40rpx 40rpx;
}
.hero-content { display: flex; flex-direction: column; align-items: center; }
.hero-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.hero-title { font-size: 44rpx; font-weight: bold; color: #fff; }
.hero-desc { font-size: 28rpx; color: rgba(255,255,255,0.85); margin-top: 12rpx; }

.quick-start { padding: 0 40rpx; margin-top: -30rpx; }
.start-btn {
  display: flex; align-items: center; justify-content: center; gap: 16rpx;
  background: #fff; border-radius: 20rpx; padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1); font-size: 32rpx; font-weight: 600; color: #e74c3c;
}
.start-icon { font-size: 40rpx; }

.section { padding: 40rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 34rpx; font-weight: bold; color: #333; }
.section-more { font-size: 26rpx; color: #999; }

.feature-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20rpx; }
.feature-card {
  display: flex; flex-direction: column; align-items: center;
  background: #fff; border-radius: 16rpx; padding: 28rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.feature-icon { width: 80rpx; height: 80rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx; }
.icon-text { font-size: 40rpx; }
.feature-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 8rpx; }
.feature-desc { font-size: 22rpx; color: #999; text-align: center; }

.agent-list { display: flex; flex-direction: column; gap: 16rpx; }
.agent-card {
  display: flex; align-items: center; gap: 20rpx;
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.agent-emoji { font-size: 48rpx; }
.agent-info { flex: 1; display: flex; flex-direction: column; }
.agent-name { font-size: 30rpx; font-weight: 600; color: #333; }
.agent-role { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.agent-arrow { font-size: 28rpx; color: #ccc; }

.footer { padding: 40rpx; text-align: center; }
.footer-text { font-size: 24rpx; color: #ccc; display: block; }
