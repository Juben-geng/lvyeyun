.container { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }
.message-list { flex: 1; padding: 20rpx; padding-bottom: 20rpx; }
.msg-row { display: flex; align-items: flex-start; margin-bottom: 24rpx; gap: 16rpx; }
.msg-row.user { flex-direction: row-reverse; }
.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #e74c3c; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; }
.user-avatar { background: #3498db; font-size: 24rpx; color: #fff; }
.bubble { max-width: 75%; padding: 20rpx 28rpx; border-radius: 20rpx; font-size: 30rpx; line-height: 1.6; position: relative; }
.bubble.assistant { background: #fff; color: #333; border-top-left-radius: 8rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.bubble.user { background: #e74c3c; color: #fff; border-top-right-radius: 8rpx; }
.msg-time { font-size: 20rpx; color: #bbb; display: block; margin-top: 8rpx; }
.bubble.user .msg-time { color: rgba(255,255,255,0.7); }
.typing { color: #999; font-size: 26rpx; }
.input-area { display: flex; align-items: center; gap: 16rpx; padding: 20rpx; background: #fff; border-top: 1rpx solid #eee; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.input { flex: 1; background: #f5f5f5; border-radius: 40rpx; padding: 20rpx 32rpx; font-size: 30rpx; }
.send-btn { background: #ddd; color: #fff; border-radius: 40rpx; padding: 20rpx 36rpx; font-size: 28rpx; font-weight: 600; }
.send-btn.active { background: #e74c3c; }
