.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.empty { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: bold; color: #333; }
.empty-desc { font-size: 28rpx; color: #999; margin-top: 12rpx; }
.empty-btn { background: #e74c3c; color: #fff; padding: 24rpx 60rpx; border-radius: 12rpx; margin-top: 40rpx; font-size: 30rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.card-header { display: flex; justify-content: space-between; align-items: center; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; }
.card-status { font-size: 24rpx; color: #e74c3c; background: #ffeaea; padding: 4rpx 16rpx; border-radius: 8rpx; }
.card-date { font-size: 26rpx; color: #666; margin-top: 12rpx; display: block; }
.card-pax { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
