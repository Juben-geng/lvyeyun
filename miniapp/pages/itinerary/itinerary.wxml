<view class="container">
  <view class="empty" wx:if="{{itineraries.length === 0}}">
    <text class="empty-icon">🗺️</text>
    <text class="empty-title">暂无行程</text>
    <text class="empty-desc">和AI助手聊聊，规划你的旅行吧！</text>
    <view class="empty-btn" bindtap="goChat">
      <text>开始规划</text>
    </view>
  </view>
  <view class="list" wx:else>
    <view class="card" wx:for="{{itineraries}}" wx:key="id">
      <view class="card-header">
        <text class="card-title">{{item.destination}}</text>
        <text class="card-status">{{item.status}}</text>
      </view>
      <text class="card-date">{{item.departure_date}}</text>
      <text class="card-pax">{{item.pax_count}}人</text>
    </view>
  </view>
</view>
