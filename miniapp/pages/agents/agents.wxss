.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.header { text-align: center; padding: 40rpx 0; }
.header-title { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.header-desc { font-size: 26rpx; color: #999; margin-top: 12rpx; display: block; }
.agent-grid { display: flex; flex-direction: column; gap: 20rpx; }
.agent-card { background: #fff; border-radius: 20rpx; padding: 32rpx; position: relative; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.card-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.agent-emoji { font-size: 48rpx; }
.agent-name { font-size: 34rpx; font-weight: 600; color: #333; }
.agent-desc { font-size: 26rpx; color: #666; }
.card-keys { display: flex; gap: 12rpx; margin-top: 16rpx; flex-wrap: wrap; }
.key-tag { background: #f0f0f0; color: #666; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; }
.card-arrow { position: absolute; right: 32rpx; top: 50%; transform: translateY(-50%); font-size: 28rpx; color: #ccc; }
