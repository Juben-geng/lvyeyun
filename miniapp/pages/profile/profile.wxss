.container { background: #f5f5f5; min-height: 100vh; padding: 30rpx; }
.user-card { background: linear-gradient(135deg, #e74c3c, #c0392b); border-radius: 20rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 30rpx; }
.avatar-area { margin-bottom: 20rpx; }
.avatar-text { font-size: 80rpx; }
.user-name { font-size: 36rpx; font-weight: bold; color: #fff; display: block; }
.user-email { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; display: block; }
.member-badge { display: inline-block; background: rgba(255,255,255,0.2); color: #fff; font-size: 22rpx; padding: 8rpx 24rpx; border-radius: 20rpx; margin-top: 16rpx; }
.login-card { background: #fff; border-radius: 20rpx; padding: 60rpx; text-align: center; margin-bottom: 30rpx; }
.login-text { font-size: 34rpx; color: #e74c3c; font-weight: 600; }
.menu-section { background: #fff; border-radius: 20rpx; overflow: hidden; margin-bottom: 30rpx; }
.menu-item { display: flex; align-items: center; padding: 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-label { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 28rpx; color: #ccc; }
.logout-btn { background: #fff; border-radius: 20rpx; padding: 32rpx; text-align: center; }
.logout-btn text { font-size: 30rpx; color: #e74c3c; }
