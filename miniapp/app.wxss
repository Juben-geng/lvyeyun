/* app.wxss — 全局样式 */
page { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 28rpx; color: #333; background: #f5f5f5; }
view, text, image, navigator, button, input, textarea { box-sizing: border-box; }
button { margin: 0; padding: 0; background: none; border: none; line-height: inherit; }
button::after { border: none; }
